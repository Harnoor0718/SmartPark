<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.PaymentController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#f0f2f5;">

    <!-- NAVBAR -->
    <top>
        <HBox style="-fx-background-color:#1a2b4a;-fx-padding:14 24;"
              alignment="CENTER_LEFT" spacing="16">
            <Label text="🅿️ SmartPark"
                   style="-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Payment"
                   style="-fx-text-fill:white;-fx-font-size:14px;-fx-opacity:0.8;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" style="-fx-padding:40 0;">
            <VBox spacing="20" maxWidth="480" minWidth="420"
                  style="-fx-background-color:white;-fx-padding:32;
                         -fx-background-radius:12;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);">

                <!-- Title -->
                <VBox alignment="CENTER" spacing="6">
                    <Label text="💳"  style="-fx-font-size:40px;"/>
                    <Label text="Complete Payment"
                           style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    <Label text="Select your payment method to proceed"
                           style="-fx-text-fill:#888;-fx-font-size:13px;"/>
                </VBox>

                <!-- Bill Summary -->
                <VBox spacing="10"
                      style="-fx-background-color:#f8f9fa;-fx-padding:16;
                             -fx-background-radius:10;-fx-border-color:#e0e0e0;
                             -fx-border-radius:10;-fx-border-width:1;">
                    <Label text="Bill Summary"
                           style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    <Label fx:id="bookingIdLabel"
                           style="-fx-font-size:13px;-fx-text-fill:#555;"/>
                    <Label fx:id="hoursLabel"
                           style="-fx-font-size:13px;-fx-text-fill:#555;"/>
                    <Label fx:id="rateLabel"
                           style="-fx-font-size:13px;-fx-text-fill:#555;"/>
                    <Label fx:id="totalAmountLabel"
                           style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;
                                  -fx-background-color:#e8f5e9;-fx-padding:8 12;
                                  -fx-background-radius:6;"/>
                </VBox>

                <!-- Payment Method -->
                <VBox spacing="10">
                    <Label text="Payment Method"
                           style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    <HBox spacing="12">
                        <Button fx:id="cashBtn" text="💵 Cash"
                                onAction="#selectCash"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#f0f2f5;-fx-text-fill:#1a2b4a;
                                       -fx-font-size:14px;-fx-font-weight:bold;-fx-padding:14;
                                       -fx-background-radius:8;-fx-border-color:#ddd;
                                       -fx-border-radius:8;-fx-cursor:hand;"/>
                        <Button fx:id="cardBtn" text="💳 Card"
                                onAction="#selectCard"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#f0f2f5;-fx-text-fill:#1a2b4a;
                                       -fx-font-size:14px;-fx-font-weight:bold;-fx-padding:14;
                                       -fx-background-radius:8;-fx-border-color:#ddd;
                                       -fx-border-radius:8;-fx-cursor:hand;"/>
                        <Button fx:id="upiBtn" text="📱 UPI"
                                onAction="#selectUpi"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#f0f2f5;-fx-text-fill:#1a2b4a;
                                       -fx-font-size:14px;-fx-font-weight:bold;-fx-padding:14;
                                       -fx-background-radius:8;-fx-border-color:#ddd;
                                       -fx-border-radius:8;-fx-cursor:hand;"/>
                    </HBox>
                    <Label fx:id="selectedMethodLabel"
                           text="No payment method selected"
                           style="-fx-text-fill:#999;-fx-font-size:12px;"/>
                </VBox>

                <!-- Error -->
                <Label fx:id="errorLabel" visible="false" wrapText="true"
                       maxWidth="Infinity"
                       style="-fx-background-color:#ffebee;-fx-text-fill:#c62828;
                              -fx-padding:10 14;-fx-border-color:#ef9a9a;
                              -fx-border-radius:8;-fx-background-radius:8;"/>

                <!-- Pay Button -->
                <Button fx:id="payBtn" text="Pay Now"
                        onAction="#handlePayment" maxWidth="Infinity"
                        style="-fx-background-color:#1a2b4a;-fx-text-fill:white;
                               -fx-font-size:15px;-fx-font-weight:bold;-fx-padding:13;
                               -fx-background-radius:8;-fx-cursor:hand;"/>

            </VBox>
        </VBox>
    </center>
</BorderPane>