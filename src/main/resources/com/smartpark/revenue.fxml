<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.RevenueController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#f0f2f5;">

    <!-- NAVBAR -->
    <top>
        <HBox style="-fx-background-color:#1a2b4a;-fx-padding:14 24;"
              alignment="CENTER_LEFT" spacing="16">
            <Label text="🅿️ SmartPark"
                   style="-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Analytics"
                   style="-fx-text-fill:white;-fx-font-size:14px;-fx-opacity:0.8;"/>
            <Button fx:id="backBtn" text="← Dashboard" onAction="#goBack"
                    style="-fx-background-color:#e74c3c;-fx-text-fill:white;
                           -fx-font-weight:bold;-fx-background-radius:6;
                           -fx-padding:8 18;-fx-cursor:hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:#f0f2f5;-fx-background:transparent;">
            <VBox spacing="20" style="-fx-padding:20;">

                <!-- Summary Cards -->
                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <VBox GridPane.columnIndex="0" alignment="CENTER" spacing="6"
                          style="-fx-background-color:white;-fx-padding:20;-fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="Total Revenue"
                               style="-fx-text-fill:#666;-fx-font-size:13px;"/>
                        <Label fx:id="totalRevenueLabel" text="..."
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#4caf50;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="1" alignment="CENTER" spacing="6"
                          style="-fx-background-color:white;-fx-padding:20;-fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="Total Bookings"
                               style="-fx-text-fill:#666;-fx-font-size:13px;"/>
                        <Label fx:id="totalBookingsLabel" text="..."
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    </VBox>
                </GridPane>

                <!-- Revenue + Occupancy Charts -->
                <VBox spacing="12"
                      style="-fx-background-color:white;-fx-padding:24;-fx-background-radius:10;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                    <Label text="Revenue &amp; Occupancy"
                           style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    <HBox spacing="16">
                        <BarChart fx:id="revenueChart" HBox.hgrow="ALWAYS" prefHeight="220">
                            <xAxis><CategoryAxis/></xAxis>
                            <yAxis><NumberAxis/></yAxis>
                        </BarChart>
                        <LineChart fx:id="occupancyChart" HBox.hgrow="ALWAYS" prefHeight="220">
                            <xAxis><CategoryAxis/></xAxis>
                            <yAxis><NumberAxis/></yAxis>
                        </LineChart>
                    </HBox>
                </VBox>

                <!-- Peak Hours Chart -->
                <VBox spacing="12"
                      style="-fx-background-color:white;-fx-padding:24;-fx-background-radius:10;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="⏰ Peak Hours"
                               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                        <Label fx:id="peakHourLabel"
                               style="-fx-font-size:13px;-fx-text-fill:#888;"/>
                    </HBox>
                    <Label text="Busiest hours of the day based on check-in activity"
                           style="-fx-font-size:12px;-fx-text-fill:#999;"/>
                    <BarChart fx:id="peakHoursChart" prefHeight="220" animated="true">
                        <xAxis>
                            <CategoryAxis label="Hour of Day"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Bookings" minorTickCount="1"/>
                        </yAxis>
                    </BarChart>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>