<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.DashboardController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#f0f4f8;">

    <top>
        <HBox style="-fx-background-color:#1a73e8; -fx-padding:14 20;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),10,0,0,2);"
              alignment="CENTER_LEFT" spacing="16">
            <Label text="🅿️ SmartPark"
                   style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:13px;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Admin Panel" onAction="#goToAdmin"
                    style="-fx-background-color:rgba(255,255,255,0.2);
                           -fx-text-fill:white; -fx-border-color:rgba(255,255,255,0.5);
                           -fx-border-radius:6; -fx-background-radius:6;
                           -fx-font-size:13px; -fx-padding:6 14; -fx-cursor:hand;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color:transparent;
                           -fx-text-fill:rgba(255,255,255,0.85);
                           -fx-font-size:13px; -fx-cursor:hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding:24;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Parking Slots"
                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#333;"/>
                <Button text="🔄 Refresh" onAction="#handleRefresh"
                        style="-fx-background-color:#e8f0fe; -fx-text-fill:#1a73e8;
                               -fx-font-size:12px; -fx-padding:6 14;
                               -fx-background-radius:20; -fx-cursor:hand;"/>
            </HBox>

            <Label fx:id="lastUpdatedLabel"
                   text="Auto-refreshing every 5 seconds..."
                   style="-fx-font-size:12px; -fx-text-fill:#aaa;"/>

            <HBox spacing="20">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="●" style="-fx-text-fill:#4caf50; -fx-font-size:16px;"/>
                    <Label text="Available — Click to Book"
                           style="-fx-font-size:13px; -fx-text-fill:#555;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="●" style="-fx-text-fill:#f44336; -fx-font-size:16px;"/>
                    <Label text="Occupied"
                           style="-fx-font-size:13px; -fx-text-fill:#555;"/>
                </HBox>
            </HBox>

            <FlowPane fx:id="slotGrid" hgap="14" vgap="14"/>

        </VBox>
    </center>

</BorderPane>