<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.DashboardController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#f0f2f5;">

    <!-- ================= NAVBAR ================= -->
    <top>
        <HBox style="-fx-background-color:#1a2b4a; -fx-padding:14 24;"
              alignment="CENTER_LEFT" spacing="16">

            <Label text="🅿️ SmartPark"
                   style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>

            <HBox HBox.hgrow="ALWAYS"/>

            <Label fx:id="navUsername"
                   style="-fx-text-fill:white; -fx-font-size:15px;"/>

            <Button text="🔑 Check In/Out"
                    style="-fx-background-color:rgba(255,255,255,0.2);
                           -fx-text-fill:white;
                           -fx-background-radius:6;
                           -fx-padding:8 16;"/>

            <Button text="⚙️ Admin"
                    onAction="#goToAdmin"
                    style="-fx-background-color:rgba(255,255,255,0.2);
                           -fx-text-fill:white;
                           -fx-background-radius:6;
                           -fx-padding:8 16;"/>

            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color:#e74c3c;
                           -fx-text-fill:white;
                           -fx-background-radius:6;
                           -fx-padding:8 18;"/>
        </HBox>
    </top>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <VBox spacing="20" style="-fx-padding:20;">

            <!-- ===== Welcome Card ===== -->
            <VBox spacing="6"
                  style="-fx-background-color:linear-gradient(to right, #1a2b4a, #c0392b);
                         -fx-padding:28 32;
                         -fx-background-radius:12;">

                <Label text="Welcome,"
                       style="-fx-text-fill:white; -fx-font-size:16px;"/>

                <Label fx:id="welcomeName"
                       style="-fx-text-fill:white; -fx-font-size:26px; -fx-font-weight:bold;"/>

                <Label text="Role:"
                       style="-fx-text-fill:white; -fx-font-size:14px;"/>

                <Label fx:id="userRole"
                       style="-fx-text-fill:white; -fx-font-size:14px;"/>
            </VBox>

            <!-- ===== Stats Grid ===== -->
            <GridPane hgap="16" vgap="16">

                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <!-- Total -->
                <VBox GridPane.columnIndex="0"
                      style="-fx-background-color:white; -fx-padding:20;
                             -fx-background-radius:10;">
                    <Label text="🚗 Total Slots"
                           style="-fx-text-fill:#666;"/>
                    <Label fx:id="totalSlots"
                           style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>
                </VBox>

                <!-- Available -->
                <VBox GridPane.columnIndex="1"
                      style="-fx-background-color:white; -fx-padding:20;
                             -fx-background-radius:10;">
                    <Label text="✅ Available"/>
                    <Label fx:id="availableSlots"
                           style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>
                </VBox>

                <!-- Occupied -->
                <VBox GridPane.columnIndex="2"
                      style="-fx-background-color:white; -fx-padding:20;
                             -fx-background-radius:10;">
                    <Label text="❌ Occupied"/>
                    <Label fx:id="occupiedSlots"
                           style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>
                </VBox>

                <!-- Location -->
                <VBox GridPane.columnIndex="3"
                      style="-fx-background-color:white; -fx-padding:20;
                             -fx-background-radius:10;">
                    <Label text="📍 Location"/>
                    <Label text="SmartPark Central"
                           style="-fx-font-size:14px; -fx-text-fill:#1a2b4a;"/>
                </VBox>

            </GridPane>

            <!-- ===== Slots Section ===== -->
            <VBox spacing="12"
                  style="-fx-background-color:white;
                         -fx-padding:24;
                         -fx-background-radius:10;">

                <Label text="Parking Slots"
                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>

                <Label fx:id="lastUpdated"
                       text="Auto-refreshing every 5 seconds..."
                       style="-fx-font-size:12px; -fx-text-fill:#999;"/>

                <!-- Legend -->
                <HBox spacing="20">
                    <Label text="● Available — Click to Book"
                           style="-fx-text-fill:#4caf50;"/>
                    <Label text="● Occupied"
                           style="-fx-text-fill:#e74c3c;"/>
                </HBox>

                <!-- Slots Grid -->
                <FlowPane fx:id="slotGrid"
                          hgap="12" vgap="12"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>