<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.RegisterController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#1a2b4a;">
    <center>
        <VBox alignment="CENTER">
            <VBox alignment="CENTER" spacing="14"
                  style="-fx-background-color:white;
                         -fx-padding:36 32;
                         -fx-background-radius:16;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.35),40,0,0,12);"
                  maxWidth="420" minWidth="380">

                <!-- LOGO -->
                <VBox alignment="CENTER" spacing="8">
                    <Label text="P"
                           style="-fx-background-color:#1a2b4a;-fx-text-fill:white;
                                  -fx-font-size:24px;-fx-font-weight:bold;-fx-alignment:center;
                                  -fx-min-width:52;-fx-min-height:52;-fx-background-radius:12;"/>
                    <Label text="SmartPark"
                           style="-fx-font-size:24px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    <Label text="Create your account"
                           style="-fx-text-fill:#888;-fx-font-size:13px;"/>
                </VBox>

                <!-- ERROR -->
                <Label fx:id="errorLabel" visible="false" wrapText="true" maxWidth="Infinity"
                       style="-fx-background-color:#ffebee;-fx-text-fill:#c62828;
                              -fx-padding:10 14;-fx-border-color:#ef9a9a;
                              -fx-border-radius:8;-fx-background-radius:8;"/>

                <!-- FULL NAME -->
                <VBox spacing="5">
                    <Label text="Full Name"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <TextField fx:id="nameField" promptText="Enter your full name"
                               style="-fx-padding:11 14;-fx-font-size:14px;
                                      -fx-border-color:#e0e0e0;-fx-border-width:2;
                                      -fx-background-radius:8;-fx-border-radius:8;"/>
                </VBox>

                <!-- EMAIL -->
                <VBox spacing="5">
                    <Label text="Email Address"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <TextField fx:id="emailField" promptText="Enter your email"
                               style="-fx-padding:11 14;-fx-font-size:14px;
                                      -fx-border-color:#e0e0e0;-fx-border-width:2;
                                      -fx-background-radius:8;-fx-border-radius:8;"/>
                </VBox>

                <!-- PASSWORD -->
                <VBox spacing="5">
                    <Label text="Password"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#444;"/>
                    <PasswordField fx:id="passwordField" promptText="Enter your password"
                                   style="-fx-padding:11 14;-fx-font-size:14px;
                                          -fx-border-color:#e0e0e0;-fx-border-width:2;
                                          -fx-background-radius:8;-fx-border-radius:8;"/>
                </VBox>

                <!-- BUTTON -->
                <Button text="Create Account" onAction="#handleRegister"
                        maxWidth="Infinity"
                        style="-fx-background-color:#1a2b4a;-fx-text-fill:white;
                               -fx-font-size:15px;-fx-font-weight:bold;-fx-padding:13;
                               -fx-background-radius:8;-fx-cursor:hand;"/>

                <!-- LOGIN LINK -->
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Already have an account?"
                           style="-fx-text-fill:#666;-fx-font-size:13px;"/>
                    <Hyperlink text="Login here" onAction="#goToLogin"
                               style="-fx-text-fill:#1a2b4a;-fx-font-weight:bold;-fx-font-size:13px;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>