<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.LoginController"
            prefWidth="800" prefHeight="600"
            style="-fx-background-color:#f0f4f8;">

    <VBox alignment="CENTER" spacing="16"
          AnchorPane.topAnchor="120"
          AnchorPane.leftAnchor="230"
          AnchorPane.rightAnchor="230"
          style="-fx-background-color:white; -fx-padding:40;
                 -fx-background-radius:12;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.1),20,0,0,4);">

        <Label text="🅿️ SmartPark"
               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#1a73e8;"/>

        <Label text="Login to your account"
               style="-fx-text-fill:#666; -fx-font-size:14px;"/>

        <Separator/>

        <TextField fx:id="usernameField"
                   promptText="Email address"
                   style="-fx-padding:12; -fx-font-size:14px;
                          -fx-background-radius:8; -fx-border-radius:8;
                          -fx-border-color:#ddd; -fx-border-width:1.5;"/>

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       style="-fx-padding:12; -fx-font-size:14px;
                              -fx-background-radius:8; -fx-border-radius:8;
                              -fx-border-color:#ddd; -fx-border-width:1.5;"/>

        <Button fx:id="loginBtn"
                text="Login"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color:#1a73e8; -fx-text-fill:white;
                       -fx-font-size:15px; -fx-padding:13;
                       -fx-background-radius:8; -fx-font-weight:bold;
                       -fx-cursor:hand;"/>

        <Label fx:id="errorLabel" visible="false"
               style="-fx-text-fill:#d93025; -fx-font-size:13px;
                      -fx-background-color:#fce8e6; -fx-padding:8 12;
                      -fx-background-radius:6;"/>

        <Label text="Don't have an account? Register below"
               style="-fx-text-fill:#999; -fx-font-size:12px;"/>

    </VBox>
</AnchorPane>