<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.smartpark.LoginController"
           style="-fx-background-color:#1a2b4a;">

    <!-- CARD -->
    <VBox alignment="CENTER" spacing="20"
          maxWidth="420"
          style="-fx-background-color:white;
                 -fx-padding:40 36;
                 -fx-background-radius:16;
                 -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.35), 40, 0, 0, 12);">

        <!-- LOGO -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="🅿"
                   style="-fx-background-color:#1a2b4a;
                          -fx-text-fill:white;
                          -fx-font-size:28px;
                          -fx-alignment:center;
                          -fx-min-width:56;
                          -fx-min-height:56;
                          -fx-background-radius:12;"/>

            <Label text="SmartPark"
                   style="-fx-font-size:26px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#1a2b4a;"/>

            <Label text="Parking Management System"
                   style="-fx-text-fill:#888;
                          -fx-font-size:14px;"/>
        </VBox>

        <!-- ERROR BOX -->
        <Label fx:id="errorLabel"
               visible="false"
               wrapText="true"
               maxWidth="Infinity"
               style="-fx-background-color:#ffebee;
                      -fx-text-fill:#c62828;
                      -fx-padding:12 16;
                      -fx-border-color:#ef9a9a;
                      -fx-border-radius:8;
                      -fx-background-radius:8;"/>

        <!-- EMAIL -->
        <VBox spacing="6">
            <Label text="Email Address"
                   style="-fx-font-size:13px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#444;"/>

            <TextField fx:id="usernameField"
                       promptText="Enter your email"
                       style="-fx-padding:13 16;
                              -fx-font-size:15px;
                              -fx-border-color:#e0e0e0;
                              -fx-border-width:2;
                              -fx-background-radius:8;
                              -fx-border-radius:8;"/>
        </VBox>

        <!-- PASSWORD -->
        <VBox spacing="6">
            <Label text="Password"
                   style="-fx-font-size:13px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#444;"/>

            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           onKeyPressed="#handleEnterKey"
                           style="-fx-padding:13 16;
                                  -fx-font-size:15px;
                                  -fx-border-color:#e0e0e0;
                                  -fx-border-width:2;
                                  -fx-background-radius:8;
                                  -fx-border-radius:8;"/>
        </VBox>

        <!-- LOGIN BUTTON -->
        <Button fx:id="loginBtn"
                text="Login"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color:#1a2b4a;
                       -fx-text-fill:white;
                       -fx-font-size:16px;
                       -fx-font-weight:bold;
                       -fx-padding:14;
                       -fx-background-radius:8;
                       -fx-cursor:hand;"
                onMouseEntered="this.setStyle('-fx-background-color:#c0392b; -fx-text-fill:white; -fx-font-size:16px; -fx-font-weight:bold; -fx-padding:14; -fx-background-radius:8;')"
                onMouseExited="this.setStyle('-fx-background-color:#1a2b4a; -fx-text-fill:white; -fx-font-size:16px; -fx-font-weight:bold; -fx-padding:14; -fx-background-radius:8;')"/>

        <!-- REGISTER LINK -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?"
                   style="-fx-text-fill:#666;"/>

            <Hyperlink text="Register here"
                       onAction="#goToRegister"
                       style="-fx-text-fill:#1a2b4a;
                              -fx-font-weight:bold;"/>
        </HBox>

    </VBox>

</StackPane>