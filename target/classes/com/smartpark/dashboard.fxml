<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.DashboardController"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox style="-fx-background-color:#1a73e8; -fx-padding:12;"
              alignment="CENTER_LEFT" spacing="20">
            <Label text="SmartPark"
                   style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:14px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding:30;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Parking Slots"
                       style="-fx-font-size:20px; -fx-font-weight:bold;"/>
                <Button text="🔄 Refresh" onAction="#handleRefresh"
                        style="-fx-background-color:#e8f0fe; -fx-text-fill:#1a73e8;
                               -fx-font-size:12px; -fx-padding:6 12;"/>
            </HBox>

            <!-- Auto-refresh indicator -->
            <Label fx:id="lastUpdatedLabel"
                   text="Auto-refreshing every 5 seconds..."
                   style="-fx-font-size:12px; -fx-text-fill:#999;"/>

            <HBox spacing="16">
                <Label text="🟢 Available — Click to Book"
                       style="-fx-font-size:13px; -fx-text-fill:#4caf50;"/>
                <Label text="🔴 Occupied"
                       style="-fx-font-size:13px; -fx-text-fill:#f44336;"/>
            </HBox>

            <FlowPane fx:id="slotGrid" hgap="12" vgap="12"/>

        </VBox>
    </center>

</BorderPane>