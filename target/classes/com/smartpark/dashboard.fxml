<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.DashboardController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#f0f2f5;">

    <!-- ================= NAVBAR ================= -->
    <top>
        <HBox style="-fx-background-color:#1a2b4a; -fx-padding:14 24;"
              alignment="CENTER_LEFT" spacing="16">

            <Label text="🅿️ SmartPark"
                   style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>

            <HBox HBox.hgrow="ALWAYS"/>

            <Label fx:id="navUsername"
                   style="-fx-text-fill:white; -fx-font-size:14px;"/>

            <Button text="🔑 Check In/Out"
                    onAction="#goToCheckIn"
                    style="-fx-background-color:rgba(255,255,255,0.15);
                           -fx-text-fill:white;
                           -fx-background-radius:6;
                           -fx-border-color:rgba(255,255,255,0.4);
                           -fx-border-radius:6;
                           -fx-padding:8 16;
                           -fx-cursor:hand;"/>

            <Button text="⚙️ Admin"
                    onAction="#goToAdmin"
                    style="-fx-background-color:rgba(255,255,255,0.15);
                           -fx-text-fill:white;
                           -fx-background-radius:6;
                           -fx-border-color:rgba(255,255,255,0.4);
                           -fx-border-radius:6;
                           -fx-padding:8 16;
                           -fx-cursor:hand;"/>

            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color:#e74c3c;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;
                           -fx-background-radius:6;
                           -fx-padding:8 18;
                           -fx-cursor:hand;"/>
        </HBox>
    </top>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#f0f2f5; -fx-background:transparent;">
            <VBox spacing="20" style="-fx-padding:20;">

                <!-- ===== Welcome Card ===== -->
                <VBox spacing="4"
                      style="-fx-background-color:linear-gradient(to right, #1a2b4a, #c0392b);
                             -fx-padding:28 32;
                             -fx-background-radius:12;">

                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Welcome, "
                               style="-fx-text-fill:white; -fx-font-size:22px;"/>
                        <Label fx:id="welcomeName"
                               style="-fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold;"/>
                        <Label text="👋"
                               style="-fx-font-size:22px;"/>
                    </HBox>

                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Role: "
                               style="-fx-text-fill:white; -fx-font-size:13px; -fx-opacity:0.85;"/>
                        <Label fx:id="userRole"
                               style="-fx-text-fill:white; -fx-font-size:13px; -fx-opacity:0.85;"/>
                    </HBox>
                </VBox>

                <!-- ===== Stats Grid ===== -->
                <GridPane hgap="16" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <!-- Total Slots -->
                    <VBox GridPane.columnIndex="0"
                          alignment="CENTER" spacing="8"
                          style="-fx-background-color:white; -fx-padding:20;
                                 -fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="🚗 Total Slots"
                               style="-fx-text-fill:#666; -fx-font-size:13px;"/>
                        <Label fx:id="totalSlots" text="..."
                               style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>
                    </VBox>

                    <!-- Available -->
                    <VBox GridPane.columnIndex="1"
                          alignment="CENTER" spacing="8"
                          style="-fx-background-color:white; -fx-padding:20;
                                 -fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="✅ Available"
                               style="-fx-text-fill:#666; -fx-font-size:13px;"/>
                        <Label fx:id="availableSlots" text="..."
                               style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#4caf50;"/>
                    </VBox>

                    <!-- Occupied -->
                    <VBox GridPane.columnIndex="2"
                          alignment="CENTER" spacing="8"
                          style="-fx-background-color:white; -fx-padding:20;
                                 -fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="❌ Occupied"
                               style="-fx-text-fill:#666; -fx-font-size:13px;"/>
                        <Label fx:id="occupiedSlots" text="..."
                               style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#e74c3c;"/>
                    </VBox>

                    <!-- Location -->
                    <VBox GridPane.columnIndex="3"
                          alignment="CENTER" spacing="8"
                          style="-fx-background-color:white; -fx-padding:20;
                                 -fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="📍 Location"
                               style="-fx-text-fill:#666; -fx-font-size:13px;"/>
                        <Label text="SmartPark Central"
                               style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>
                    </VBox>
                </GridPane>

                <!-- ===== Slots Section ===== -->
                <VBox spacing="12"
                      style="-fx-background-color:white;
                             -fx-padding:24;
                             -fx-background-radius:10;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">

                    <Label text="Parking Slots"
                           style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1a2b4a;"/>

                    <Label fx:id="lastUpdated"
                           text="Auto-refreshing every 5 seconds..."
                           style="-fx-font-size:12px; -fx-text-fill:#999;"/>

                    <!-- Legend -->
                    <HBox spacing="24">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●"
                                   style="-fx-text-fill:#4caf50; -fx-font-size:16px;"/>
                            <Label text="Available — Click to Book"
                                   style="-fx-text-fill:#555; -fx-font-size:13px;"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●"
                                   style="-fx-text-fill:#e74c3c; -fx-font-size:16px;"/>
                            <Label text="Occupied"
                                   style="-fx-text-fill:#555; -fx-font-size:13px;"/>
                        </HBox>
                    </HBox>

                    <!-- Slots Grid -->
                    <FlowPane fx:id="slotGrid" hgap="12" vgap="12"/>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>