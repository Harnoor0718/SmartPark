<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.AdminController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color:#f0f2f5;">

    <!-- NAVBAR -->
    <top>
        <HBox style="-fx-background-color:#1a2b4a;-fx-padding:14 24;"
              alignment="CENTER_LEFT" spacing="16">
            <Label text="🅿️ SmartPark"
                   style="-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Admin Panel"
                   style="-fx-text-fill:white;-fx-font-size:14px;-fx-opacity:0.8;"/>
            <Button text="🔄 Refresh" onAction="#handleRefresh"
                    style="-fx-background-color:rgba(255,255,255,0.15);-fx-text-fill:white;
                           -fx-background-radius:6;-fx-border-color:rgba(255,255,255,0.4);
                           -fx-border-radius:6;-fx-padding:8 16;-fx-cursor:hand;"/>
            <Button text="📊 Analytics" onAction="#goToAnalytics"
                    style="-fx-background-color:rgba(255,255,255,0.15);-fx-text-fill:white;
                           -fx-background-radius:6;-fx-border-color:rgba(255,255,255,0.4);
                           -fx-border-radius:6;-fx-padding:8 16;-fx-cursor:hand;"/>
            <Button fx:id="backBtn" text="← Dashboard" onAction="#goBack"
                    style="-fx-background-color:#e74c3c;-fx-text-fill:white;
                           -fx-font-weight:bold;-fx-background-radius:6;
                           -fx-padding:8 18;-fx-cursor:hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:#f0f2f5;-fx-background:transparent;">
            <VBox spacing="20" style="-fx-padding:20;">

                <!-- Stats Row -->
                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.3"/>
                        <ColumnConstraints percentWidth="33.3"/>
                        <ColumnConstraints percentWidth="33.3"/>
                    </columnConstraints>

                    <VBox GridPane.columnIndex="0" alignment="CENTER" spacing="6"
                          style="-fx-background-color:white;-fx-padding:20;-fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="Total Slots" style="-fx-text-fill:#666;-fx-font-size:13px;"/>
                        <Label fx:id="totalSlotsLabel" text="..."
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="1" alignment="CENTER" spacing="6"
                          style="-fx-background-color:white;-fx-padding:20;-fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="Occupied" style="-fx-text-fill:#666;-fx-font-size:13px;"/>
                        <Label fx:id="occupiedSlotsLabel" text="..."
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#e74c3c;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="2" alignment="CENTER" spacing="6"
                          style="-fx-background-color:white;-fx-padding:20;-fx-background-radius:10;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                        <Label text="Available" style="-fx-text-fill:#666;-fx-font-size:13px;"/>
                        <Label fx:id="availableSlotsLabel" text="..."
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#4caf50;"/>
                    </VBox>
                </GridPane>

                <!-- Slot Table -->
                <VBox spacing="12"
                      style="-fx-background-color:white;-fx-padding:24;-fx-background-radius:10;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                    <Label text="Slot Management"
                           style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1a2b4a;"/>
                    <TableView fx:id="slotTable" prefHeight="280">
                        <columns>
                            <TableColumn fx:id="slotNameCol"   text="Slot Name" prefWidth="300"/>
                            <TableColumn fx:id="slotStatusCol" text="Status"    prefWidth="300"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>