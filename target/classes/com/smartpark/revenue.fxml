<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.RevenueController"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox style="-fx-background-color:#1a73e8; -fx-padding:12;"
              alignment="CENTER_LEFT" spacing="20">
            <Label text="SmartPark — Analytics"
                   style="-fx-text-fill:white; -fx-font-size:20px; -fx-font-weight:bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding:20;">

            <!-- Summary Cards -->
            <HBox spacing="16">
                <VBox style="-fx-background-color:#e8f5e9; -fx-padding:16;
                             -fx-background-radius:8;" HBox.hgrow="ALWAYS">
                    <Label fx:id="totalRevenueLabel"
                           style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#4caf50;"/>
                </VBox>
                <VBox style="-fx-background-color:#e3f2fd; -fx-padding:16;
                             -fx-background-radius:8;" HBox.hgrow="ALWAYS">
                    <Label fx:id="totalBookingsLabel"
                           style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#1a73e8;"/>
                </VBox>
            </HBox>

            <!-- Charts -->
            <HBox spacing="16">
                <BarChart fx:id="revenueChart" HBox.hgrow="ALWAYS"
                          prefHeight="250">
                    <xAxis><CategoryAxis/></xAxis>
                    <yAxis><NumberAxis/></yAxis>
                </BarChart>

                <LineChart fx:id="occupancyChart" HBox.hgrow="ALWAYS"
                           prefHeight="250">
                    <xAxis><CategoryAxis/></xAxis>
                    <yAxis><NumberAxis/></yAxis>
                </LineChart>
            </HBox>

            <Button fx:id="backBtn" text="← Back to Dashboard"
                    onAction="#goBack"
                    style="-fx-background-color:#eee; -fx-text-fill:#333;
                           -fx-font-size:14px; -fx-padding:12;"/>

        </VBox>
    </center>

</BorderPane>