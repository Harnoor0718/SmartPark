<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpark.BookingController"
            prefWidth="900" prefHeight="600">

    <VBox spacing="20"
          AnchorPane.topAnchor="60"
          AnchorPane.leftAnchor="250"
          AnchorPane.rightAnchor="250">

        <Label text="Book a Parking Slot"
               style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#1a73e8;"/>

        <Label fx:id="slotLabel"
               style="-fx-font-size:16px; -fx-text-fill:#333;"/>

        <Label text="Vehicle Type:"/>
        <ComboBox fx:id="vehicleTypeBox" maxWidth="Infinity"/>

        <Label text="Vehicle Plate Number:"/>
        <TextField fx:id="vehiclePlateField"
                   promptText="e.g. PB-01-AB-1234"
                   style="-fx-padding:12; -fx-font-size:14px;"/>

        <Button fx:id="confirmBtn"
                text="Confirm Booking"
                onAction="#handleConfirmBooking"
                maxWidth="Infinity"
                style="-fx-background-color:#1a73e8; -fx-text-fill:white;
                       -fx-font-size:14px; -fx-padding:12;"/>

        <Button text="← Back to Dashboard"
                onAction="#goBack"
                maxWidth="Infinity"
                style="-fx-background-color:#eee; -fx-text-fill:#333;
                       -fx-font-size:14px; -fx-padding:12;"/>

        <Label fx:id="errorLabel" visible="false"
               style="-fx-text-fill:red; -fx-font-size:13px;"/>

    </VBox>
</AnchorPane>